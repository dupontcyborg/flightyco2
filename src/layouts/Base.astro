---
import "~/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "flightyco2 — Your Flighty history, in tons of CO₂",
  description = "Drop your Flighty CSV and see the CO₂ footprint of your travel history, including non-CO₂ warming effects. Computed locally with Google's Travel Impact Model and DEFRA 2024 — your data never leaves your browser.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og.png", Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0c" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="flightyco2" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Plausible analytics, proxied through the shared CloudFront distribution
        so privacy-focused adblockers don't drop the script or /api/event POSTs.
        Queue shim lets us call window.plausible(...) before the script loads. */}
    <script is:inline>
      window.plausible = window.plausible || function () {
        (window.plausible.q = window.plausible.q || []).push(arguments);
      };
    </script>
    <script defer data-domain="flightyco2.com" src="https://d1w0psmo3bkh8z.cloudfront.net/js/script.js" is:inline></script>
  </head>
  <body>
    <slot />
  </body>
</html>
