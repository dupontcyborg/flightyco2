---
import "~/styles/global.css";

interface Props {
  title?: string;
}

const { title = "Flight Carbon Footprint" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased">
    <slot />
  </body>
</html>
