{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
