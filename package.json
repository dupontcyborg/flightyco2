{
  "name": "flightyco2",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "PUBLIC_DEBUG_IMPORT=1 astro dev",
    "build": "astro build",
    "prebuild": "tsx scripts/hash-public-assets.ts && tsx scripts/build-og.ts",
    "predev": "tsx scripts/hash-public-assets.ts",
    "hash-assets": "tsx scripts/hash-public-assets.ts",
    "build:og": "tsx scripts/build-og.ts",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "data": "tsx scripts/update-data.ts",
    "data:airports": "tsx scripts/update-airports.ts",
    "data:gaia": "tsx scripts/update-gaia.ts",
    "data:eea": "tsx scripts/update-eea.ts",
    "data:seats": "tsx scripts/build-seat-configs.ts",
    "data:tim": "tsx scripts/update-tim-mapping.ts",
    "data:defra": "tsx scripts/update-defra.ts"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.1.0",
    "astro": "^6.3.1",
    "numpy-ts": "^1.3.2",
    "papaparse": "^5.5.3",
    "svelte": "^5.55.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.15",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/papaparse": "^5.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "exceljs": "^4.4.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.4"
  }
}
