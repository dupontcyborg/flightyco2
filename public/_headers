# Cloudflare Pages / Netlify cache headers.
#
# Reference JSON files served from /public are content-addressable
# (filenames include a SHA-256 hash, generated by
# `scripts/hash-public-assets.ts`). When source content changes the URL
# changes, so it's safe to cache these forever.

# Hashed reference data — 1-year TTL, immutable, served by CDN edge
/*.????????.json
  Cache-Control: public, max-age=31536000, immutable

# The unhashed source files are kept in /public for direct inspection.
# They aren't fetched by the running app (loaders use the hashed URLs from
# the asset manifest), but if anything DOES hit them, send a short TTL so
# a content change isn't sticky.
/*.json
  Cache-Control: public, max-age=300, must-revalidate

# HTML entry points — short TTL, must revalidate (so the next deploy lands
# quickly for returning users).
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Default for anything else (CSS, fonts, etc. that Astro emits with its own
# fingerprinting under /_astro/*) — Astro's own assets already have content
# hashes so a long TTL is safe.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
